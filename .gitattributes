# Handle line endings automatically for text files
* text=auto
# Explicitly mark binary files to prevent corruption
*.onnx binary
*.onnx.data binary
*.bin binary
*.jpg binary
*.png binary
*.gif binary
*.ico binary
# Standardize endings for code/config files
*.cs text eol=crlf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sql text eol=crlf
backend/MLModels/*.onnx filter=lfs diff=lfs merge=lfs -text
backend/MLModels/*.data filter=lfs diff=lfs merge=lfs -text
