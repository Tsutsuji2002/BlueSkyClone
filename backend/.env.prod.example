# Production Environment Variables for Backend
# Rename this file to .env and fill in the values

# Database Configuration
# In docker-compose.prod.yml, the server name will be 'sql-server'
DB_PASSWORD=YourStrongPassword123!
CONNECTION_STRING="Server=sql-server;Database=BlueSkyClone;User Id=sa;Password=${DB_PASSWORD};TrustServerCertificate=True;"

# Security
JWT_KEY=a_very_long_random_secret_string_change_this_for_prod
JWT_ISSUER=BSkyCloneAPI
JWT_AUDIENCE=BSkyCloneWeb

# Redis
REDIS_CONNECTION=redis:6379
